# Streamlit Community Cloud secrets template.
# DO NOT put real values here or commit a filled-in secrets.toml.
# On share.streamlit.io: App → Settings → Secrets → paste the lines below with real values.
#
# The dashboard only needs the mandi-price key; weather (Open-Meteo) and
# NDVI (NASA ORNL) are keyless. The rest are only needed if you also run the
# WhatsApp agent from the same deployment.

DATA_GOV_IN_API_KEY = "your-data-gov-in-key"

# Optional — only if the WhatsApp agent runs here too:
# GROQ_API_KEY = "..."
# GEMINI_API_KEY = "..."
# TWILIO_ACCOUNT_SID = "..."
# TWILIO_AUTH_TOKEN = "..."
# TWILIO_WHATSAPP_FROM = "whatsapp:+14155238886"
# OFFICER_WHATSAPP_TO = "+91..."
